[Unit]
Description=Flask Application
After=network.target postgresql.service

[Service]
Type=exec
User=www-data
Group=www-data
WorkingDirectory={{ app_path }}
Environment="PATH={{ app_path }}/venv/bin"
Environment="FLASK_APP={{ app_path }}/app.py"
Environment="DB_HOST=localhost"
Environment="DB_PORT=5432"
Environment="DB_NAME={{ vault_db_name }}"
Environment="DB_USER={{ vault_db_user }}"
Environment="DB_PASSWORD={{ vault_db_password }}"
ExecStart={{ app_path }}/venv/bin/gunicorn --workers 3 --bind 127.0.0.1:5000 app:app
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target